---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import { t } from "@utils/translations";

const currentLocale = Astro.currentLocale ?? "ja";
const pageTitle = "404";
---

<BaseLayout pageTitle={t(currentLocale, "notFoundTitle")}>
  <Hero headline={pageTitle}>
    <p class="max-w-prose leading-6">
      {t(currentLocale, "notFoundMessage")}
    </p>
    <a
      href="/ja/"
      class="inline-block mt-5 px-6 py-3 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 rounded hover:bg-gray-700 dark:hover:bg-gray-300 transition-colors"
    >
      {t(currentLocale, "backToHome")}
    </a>
  </Hero>
</BaseLayout>
