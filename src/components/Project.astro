---
import { Image } from "astro:assets";
import TertiaryHeadline from "./TertiaryHeadline.astro";

interface Props {
  thumbnail: ImageMetadata;
  thumbnailAlt: string;
  headline: string;
  url: string;
  description?: string;
  fullWidth?: boolean;
}

const {
  thumbnail,
  thumbnailAlt,
  headline,
  url,
  description,
  fullWidth = false,
} = Astro.props;
---

<a class="group relative block" href={url} target="_blank">
  <div class="grid items-start gap-y-6">
    {
      thumbnail && (
        <div class="aspect-project rounded-3xl overflow-hidden bg-[--color-surface] shadow-[--shadow-md] group-hover:shadow-[--shadow-xl] transition-all duration-300 ring-1 ring-black/5">
          <Image
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            src={thumbnail}
            alt={thumbnailAlt}
            widths={[400, 800, 1200, 1600]}
            sizes="(max-width: 640px) 100vw, 50vw"
            loading="lazy"
            quality="mid"
          />
        </div>
      )
    }
    <div class="flex flex-col gap-3">
      {headline && <TertiaryHeadline text={headline} />}
      {
        description && (
          <p
            class:list={[
              "text-[--color-text-secondary] leading-relaxed",
              fullWidth ? "max-w-[80ch]" : "max-w-[40ch]",
            ]}
          >
            {description}
          </p>
        )
      }
    </div>
  </div>
</a>
