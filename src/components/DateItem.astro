---
import { formatDate } from "@utils/date";
import { t } from "@utils/translations";

interface Props {
  type: string;
  title: string;
  startDate?: string;
  endDate?: string;
  dark?: boolean;
  locale?: string;
}

const { type, title, startDate, endDate, dark, locale = "en" } = Astro.props;
---

<div
  class="flex gap-x-5 gap-y-1 items-start justify-between pt-3 border-t border-gray border-solid max-md:flex-col"
>
  <h4 class:list={["md:text-xl", { "text-gray-400": dark }]}>
    {title}
  </h4>
  <div
    class:list={[
      "flex flex-wrap items-center gap-1",
      { "text-gray-400": dark },
    ]}
  >
    {
      startDate && (
        <>
          <time datetime={startDate}>{formatDate(startDate, locale)}</time>
          <div>-</div>
        </>
      )
    }
    {
      endDate ? (
        <time datetime={endDate}>{formatDate(endDate, locale)}</time>
      ) : (
        <span>{t(locale, "present")}</span>
      )
    }
  </div>
</div>
