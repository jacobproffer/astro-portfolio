---
import Container from "@components/Container.astro";

interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section
  class={`py-20 ${dark ? "text-[--color-text-primary] bg-[--color-surface]" : ""}`}
>
  <Container>
    <div class="grid gap-y-16 lg:gap-y-24">
      <slot />
    </div>
  </Container>
</section>
