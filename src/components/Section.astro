---
import Container from "@components/Container.astro";

interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section class={`py-10 lg:py-20 ${dark ? "text-white bg-black" : ""}`}>
  <Container>
    <div class="grid gap-y-10 lg:gap-y-15">
      <slot />
    </div>
  </Container>
</section>
