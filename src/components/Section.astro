---
import Container from "@components/Container.astro";

interface Props {
  dark?: boolean;
}

const { dark = false } = Astro.props;
---

<section class={dark ? "py-20 text-white bg-black" : "py-20"}>
  <Container>
    <div class="grid gap-y-15">
      <slot />
    </div>
  </Container>
</section>
