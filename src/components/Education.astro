---
import AboutSection from "@components/AboutSection.astro";
import DateItem from "@components/DateItem.astro";
import TertiaryHeadline from "./TertiaryHeadline.astro";
---

<AboutSection secondaryHeadline="Education">
  <div
    class="education-item grid gap-3 p-3 m-3 bg-mid-blue border border-black border-t-highlight border-l-highlight"
    data-animate
  >
    <TertiaryHeadline text="Northern Michigan University" />
    <DateItem
      type="education"
      title="Bachelor of Fine Arts in Computer Art"
      startDate="2010-08"
      endDate="2014-05"
    />
  </div>
</AboutSection>

<script>
  import { animateOnScroll } from "../utils/animations";

  // Animate education section as it scrolls into view
  const educationItem = document.querySelector(".education-item");
  if (educationItem) {
    animateOnScroll(educationItem);
  }
</script>
