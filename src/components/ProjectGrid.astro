---
import Section from "@components/Section.astro";
import SecondaryHeadline from "@components/SecondaryHeadline.astro";
import Project from "@components/Project.astro";
import { getCollection } from "astro:content";

interface Props {
  headline: string;
}

const { headline } = Astro.props;

// Load projects from content collection
const projects = (await getCollection("projects")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<Section dark>
  <SecondaryHeadline text={headline} />
  <ol class="grid gap-y-15 gap-x-10 md:grid-cols-2">
    {
      projects.map((entry, index: number) => (
        <li class="project-item" data-animate>
          <Project
            url={entry.data.url}
            headline={entry.data.title}
            tags={entry.data.tags ?? []}
            thumbnail={entry.data.thumbnail}
            thumbnailAlt=""
          />
        </li>
      ))
    }
  </ol>
</Section>

<script>
  import { animateOnScroll } from "../utils/animations";

  // Animate each project as it scrolls into view
  document.querySelectorAll(".project-item").forEach((item) => {
    animateOnScroll(item);
  });
</script>
