---
import Section from "@components/Section.astro";
import SecondaryHeadline from "@components/SecondaryHeadline.astro";
import Project from "@components/Project.astro";
import { getCollection } from "astro:content";
import { filterByLocale } from "@utils/locale";

interface Props {
  headline: string;
}

const { headline } = Astro.props;

const currentLocale = Astro.currentLocale ?? "en";

// Load projects from content collection and filter by locale
const allProjects = await getCollection("projects");
const projects = filterByLocale(allProjects, currentLocale).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<Section>
  <SecondaryHeadline text={headline} />
  <ol class="grid gap-y-12 gap-x-2 md:grid-cols-2">
    {
      projects.map((entry, index: number) => {
        const isFullWidth = (index + 1) % 3 === 0;
        return (
          <li
            class={`project-item ${isFullWidth ? "lg:col-span-full" : ""}`}
            data-animate
          >
            <Project
              url={entry.data.url}
              headline={entry.data.title}
              description={entry.data.description}
              thumbnail={entry.data.thumbnail}
              thumbnailAlt=""
              fullWidth={isFullWidth}
            />
          </li>
        );
      })
    }
  </ol>
</Section>

<script>
  import { animateOnScroll } from "../utils/animations";

  // Animate each project as it scrolls into view
  document.querySelectorAll(".project-item").forEach((item) => {
    animateOnScroll(item);
  });
</script>
