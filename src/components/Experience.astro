---
import AboutSection from "@components/AboutSection.astro";
import DateItem from "@components/DateItem.astro";
import TertiaryHeadline from "@components/TertiaryHeadline.astro";
import { getCollection } from "astro:content";
import { filterByLocale } from "@utils/locale";
import { t } from "@utils/translations";

const currentLocale = Astro.currentLocale ?? "en";

// Load experience from content collection and filter by locale
const allExperience = await getCollection("experience");
const experienceItems = filterByLocale(allExperience, currentLocale);
// Sort by order field
const sortedExperience = experienceItems.sort(
  (a, b) => a.data.order - b.data.order,
);
---

<AboutSection secondaryHeadline={t(currentLocale, "experience")}>
  {
    sortedExperience?.length && (
      <ol class="grid gap-10">
        {sortedExperience.map((item) => (
          <li class="experience-item flex flex-col gap-5" data-animate>
            <TertiaryHeadline text={item.data.company} />
            {item.data.positions?.length &&
              (item.data.positions.length === 1 ? (
                <DateItem
                  type="Experience"
                  title={item.data.positions[0].position}
                  startDate={item.data.positions[0].startDate}
                  endDate={item.data.positions[0].endDate}
                  locale={currentLocale}
                />
              ) : (
                <ol class="grid gap-3">
                  {item.data.positions.map((position) => (
                    <li>
                      <DateItem
                        type="Experience"
                        title={position.position}
                        startDate={position.startDate}
                        endDate={position.endDate}
                        locale={currentLocale}
                      />
                    </li>
                  ))}
                </ol>
              ))}
          </li>
        ))}
      </ol>
    )
  }
</AboutSection>

<script>
  import { animateOnScroll } from "../utils/animations";

  // Animate each experience item as it scrolls into view
  document.querySelectorAll(".experience-item").forEach((item) => {
    animateOnScroll(item);
  });
</script>
