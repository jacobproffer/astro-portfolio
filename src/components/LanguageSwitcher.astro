---
import { getRelativeLocaleUrl } from "astro:i18n";

const currentLocale = Astro.currentLocale ?? "en";

// Get the current path without locale prefix
const currentPath = Astro.url.pathname.replace(/^\/(en|ja)/, "") || "/";

const languages = [
  { code: "en", label: "EN", name: "English" },
  { code: "ja", label: "日本語", name: "Japanese" },
];
---

<nav class="max-w-max" aria-label="Language switcher">
  <ul
    class="flex items-center gap-2 px-2 py-2 bg-gray-100 rounded-full shadow-sm border border-gray-200"
  >
    {
      languages.map((lang) => {
        const isCurrent = currentLocale === lang.code;
        const ariaLabel = isCurrent
          ? `Current language: ${lang.name}`
          : `Switch to ${lang.name}`;

        return (
          <li>
            <a
              href={getRelativeLocaleUrl(lang.code, currentPath.slice(1))}
              class:list={[
                "text-sm transition-all duration-200 px-4 py-1.5 rounded-full block",
                {
                  "font-semibold bg-white text-gray-900 shadow-sm": isCurrent,
                  "text-gray-600 hover:text-gray-900 hover:bg-white/60":
                    !isCurrent,
                },
              ]}
              aria-label={ariaLabel}
              aria-current={isCurrent ? "page" : undefined}
            >
              {lang.label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>
