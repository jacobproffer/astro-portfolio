---
import Section from "./Section.astro";

interface Props {
  headline: string;
}

const { headline } = Astro.props;
---

<Section>
  <div class="flex flex-col gap-y-8 md:gap-y-10 py-8 md:py-16">
    {
      headline && (
        <h1 class="text-6xl font-semibold tracking-tight text-[--color-text-primary] md:text-7xl lg:text-8xl xl:text-[6rem] xl:leading-[1.05] animate-fade-in">
          {headline}
        </h1>
      )
    }

    <div class="animate-fade-in-delay">
      <slot />
    </div>
  </div>
</Section>
