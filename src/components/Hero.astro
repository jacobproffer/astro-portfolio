---
import Section from "./Section.astro";

interface Props {
  headline: string;
}

const { headline } = Astro.props;
---

<Section>
  <div class="flex flex-col gap-y-5">
    {
      headline && (
        <h1 class="text-4xl font-semibold md:text-6xl xl:text-8xl">
          {headline}
        </h1>
      )
    }

    <slot />
  </div>
</Section>
